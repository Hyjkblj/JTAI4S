{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xtalloop.local/schemas/golden-set-entry.schema.json",
  "title": "XtalLoop Golden Set Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sample_id",
    "language",
    "data_origin",
    "scenario_tags",
    "meeting",
    "utterance",
    "expected_claims",
    "annotation_status"
  ],
  "properties": {
    "sample_id": {
      "type": "string",
      "pattern": "^GS-[0-9]{3}$"
    },
    "language": {
      "enum": [
        "zh-CN",
        "en-US",
        "mixed"
      ]
    },
    "data_origin": {
      "enum": [
        "synthetic",
        "deidentified",
        "real_authorized"
      ]
    },
    "scenario_tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "meeting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "meeting_id",
        "experiment_id",
        "title",
        "occurred_at"
      ],
      "properties": {
        "meeting_id": {
          "type": "string",
          "pattern": "^MTG-[A-Z0-9-]{4,}$"
        },
        "experiment_id": {
          "type": "string",
          "pattern": "^EXP-[A-Z0-9-]{4,}$"
        },
        "title": {
          "type": "string",
          "minLength": 3
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "utterance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "utterance_id",
        "speaker_id",
        "speaker_role",
        "start_ms",
        "end_ms",
        "text"
      ],
      "properties": {
        "utterance_id": {
          "type": "string",
          "pattern": "^UTT-[A-Z0-9-]{4,}$"
        },
        "speaker_id": {
          "type": "string",
          "minLength": 3
        },
        "speaker_role": {
          "enum": [
            "algorithm",
            "experiment",
            "materials",
            "manager",
            "automation",
            "unknown"
          ]
        },
        "start_ms": {
          "type": "integer",
          "minimum": 0
        },
        "end_ms": {
          "type": "integer",
          "minimum": 1
        },
        "text": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "expected_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./scientific-claim.schema.json"
      }
    },
    "annotation_status": {
      "enum": [
        "draft",
        "single_reviewed",
        "double_reviewed"
      ]
    },
    "annotation_notes": {
      "type": "string"
    }
  }
}

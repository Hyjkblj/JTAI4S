# XtalLoop public example configuration.
# Copy to .env.local for private experiments. Never commit real values.

# Public/offline demo mode does not require Feishu credentials.
XTALLOOP_MODE=offline_demo

# Optional: set to real_feishu only in a private tenant workspace.
# XTALLOOP_MODE=real_feishu

# lark-cli profile names. The public repo assumes these names in docs and plans.
XTALLOOP_FEISHU_READER_PROFILE=xtal-reader
XTALLOOP_FEISHU_WRITER_PROFILE=xtal-writer

# Optional real Feishu identifiers for private smoke tests.
# Keep them in .env.local or .tmp/, not in Git.
XTALLOOP_MEETING_ID=
XTALLOOP_MINUTE_TOKEN=
XTALLOOP_NOTE_ID=

# Private writeback targets for real dry-run only.
# These are intentionally empty in the public repo.
XTALLOOP_REVIEW_BASE_TOKEN=
XTALLOOP_REVIEW_TABLE_ID=
XTALLOOP_KNOWLEDGE_FOLDER_TOKEN=

# Real dry-run execution is disabled unless explicitly opted in.
XTALLOOP_ALLOW_REAL_DRY_RUN=0
